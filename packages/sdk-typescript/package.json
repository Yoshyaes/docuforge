{
  "name": "deckle",
  "version": "0.5.0",
  "author": "Deckle",
  "homepage": "https://getdeckle.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yoshyaes/deckle/deckle"
  },
  "bugs": "https://github.com/Yoshyaes/deckle/deckle/issues",
  "description": "Deckle - PDF generation API for developers. HTML in, pixel-perfect PDF out.",
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "keywords": [
    "pdf",
    "html-to-pdf",
    "pdf-generation",
    "api",
    "deckle"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8",
    "typescript": "^5.4",
    "vitest": "^4.0.18"
  }
}
