{
  "name": "@deckle/react-pdf",
  "version": "0.1.0",
  "description": "React components for building pixel-perfect PDF documents with Deckle",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "sideEffects": false,
  "license": "MIT",
  "keywords": [
    "react",
    "pdf",
    "pdf-generation",
    "deckle",
    "document",
    "invoice",
    "report",
    "react-components",
    "html-to-pdf",
    "table",
    "watermark",
    "barcode",
    "qrcode"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Yoshyaes/deckle",
    "directory": "packages/react"
  },
  "homepage": "https://getdeckle.dev/docs/react-components",
  "bugs": "https://github.com/Yoshyaes/deckle/issues",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.1",
    "tsup": "^8",
    "typescript": "^5.0.0"
  }
}
